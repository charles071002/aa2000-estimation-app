# Copy this file to `.env` and fill in real values. Never commit `.env`.

GEMINI_API_KEY=your_gemini_api_key_here
API_KEY=https://your-backend-base-url.example.com

# Client-side API base URL (must start with VITE_ for Vite)
VITE_API_BASE_URL=https://your-backend-base-url.example.com

# Optional: auth key for estimation upload API
# VITE_API_KEY=your-api-key
